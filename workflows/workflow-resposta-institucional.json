      "parameters": {
        "fromEmail": "secretaria@universidade.edu.br",
        "toEmail": "={{ $json.remetente }}",
        "subject": "=Re: {{ $json.assunto }}",
        "emailType": "text",
        "message": "Prezado(a) Aluno(a),\n\nObrigado por entrar em contato conosco!\n\nRecebemos sua mensagem e um de nossos atendentes irá responder em breve.\n\n⏰ Tempo médio de resposta: até 24 horas úteis\n\n📋 Se precisar de ajuda imediata, confira:\n• Portal do Aluno: https://portal.universidade.edu.br\n• FAQ: https://universidade.edu.br/faq\n\n📞 Contatos:\n• Secretaria: (11) 99999-9999\n• E-mail: secretaria@universidade.edu.br\n\nAtenciosamente,\nSecretaria Acadêmica\nUniversidade Exemplo",
        "options": {}
