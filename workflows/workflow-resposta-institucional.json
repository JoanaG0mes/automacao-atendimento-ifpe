    {
      "parameters": {
        "fromEmail": "financeiro@universidade.edu.br",
        "toEmail": "={{ $json.remetente }}",
        "subject": "=Re: {{ $json.assunto }}",
        "emailType": "text",
        "message": "Prezado(a) Aluno(a),\n\nObrigado por contatar o Departamento Financeiro!\n\nINFORMAÇÕES FINANCEIRAS:\n\n💳 Valores das Mensalidades (2026):\n• Graduação Presencial: R$ 890,00\n• Graduação EAD: R$ 450,00\n• Pós-Graduação: R$ 1.200,00\n\n📅 Vencimento:\n• Dia 10 de cada mês\n• Pagamento após vencimento: acréscimo de 2% + juros\n\n📍 Como Pagar:\n1. Portal do Aluno → Financeiro\n2. Boleto bancário (enviado por e-mail)\n3. Pix: financeiro@universidade.edu.br\n4. Cartão de crédito (recorrente disponível)\n\n📞 Contato Financeiro:\n• E-mail: financeiro@universidade.edu.br\n• Telefone: (11) 99999-8888\n• Atendimento: Seg-Sex, 09:00 às 17:00\n\n🔑 Dúvidas? Acesse nossa FAQ:\nhttps://universidade.edu.br/faq-financeiro\n\nAtenciosamente,\nDepartamento Financeiro\nUniversidade Exemplo",
        "options": {}
      },
      "id": "7-email-financeiro",
      "name": "Enviar E-mail: Financeiro",
      "type": "n8n-nodes-base.emailSend",
