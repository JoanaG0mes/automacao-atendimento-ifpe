    {
      "parameters": {
        "fromEmail": "secretaria@universidade.edu.br",
        "toEmail": "={{ $json.remetente }}",
        "subject": "=Re: {{ $json.assunto }}",
        "emailType": "text",
        "message": "Prezado(a) Aluno(a),\n\nAgradecemos pelo contato sobre documentos.\n\nSOLICITAÇÃO DE DOCUMENTOS:\n\n📄 Tipos de Documentos Disponíveis:\n1. Declaração de Matrícula\n2. Histórico Escolar\n3. Certificado de Conclusão\n4. Boletim de Notas\n\n📍 Como Solicitar:\n1. Acesse o Portal do Aluno: https://portal.universidade.edu.br\n2. Menu: \"Documentos\" → \"Solicitar Documento\"\n3. Selecione o tipo de documento desejado\n4. Confira os dados e finalize a solicitação\n\n⏰ Prazo de Entrega:\n• Documentos digitais: até 24 horas\n• Documentos impressos: até 3 dias úteis\n\n💲 Taxas:\n• Declaração de Matrícula: Gratuita\n• Histórico Escolar: R$ 15,00\n• Certificado: R$ 25,00\n\nAtenciosamente,\nSecretaria Acadêmica\nUniversidade Exemplo\nTelefone: (11) 99999-9999",
        "options": {}
      },
